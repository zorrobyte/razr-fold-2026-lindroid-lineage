diff --git a/core/res/res/values/config.xml b/core/res/res/values/config.xml
index fbe4c3280e49..2c866495f22e 100644
--- a/core/res/res/values/config.xml
+++ b/core/res/res/values/config.xml
@@ -6596,6 +6596,13 @@
         split screen. -->
     <bool name="config_isWindowManagerCameraCompatTreatmentEnabled">false</bool>
 
+    <!-- When true, report the inner front camera as covered (DEVICE_STATE_FRONT_COVERED)
+         to the camera service while the device is folded, in addition to
+         DEVICE_STATE_FOLDED. Some foldable vendor HALs (e.g. Motorola razr's CamX)
+         require this to route the logical front camera to the outer/cover lens when
+         folded, and reject opening it otherwise. -->
+    <bool name="config_cameraFrontCoveredWhenFolded">false</bool>
+
     <!-- Whether should use split screen aspect ratio for the activity when camera compat treatment
         is enabled and activity is connected to the camera in fullscreen. -->
     <bool name="config_isWindowManagerCameraCompatSplitScreenAspectRatioEnabled">false</bool>
